# Anthropic API Key (required — default provider)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Optional: any of the other supported providers (select with --provider <name>)
# OPENAI_API_KEY=sk-...
# AI_GATEWAY_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# XAI_API_KEY=xai-...

# Optional overrides (defaults shown). Also settable via --provider / --model flags.
# PROVIDER=anthropic        # anthropic | openai | ai-gateway | openrouter | xai
# MODEL=claude-sonnet-4-6
